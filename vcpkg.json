{
    "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
    "name": "podradio",
    "version": "0.5.0",
    "description": "Terminal Podcast/Radio Player - A cross-platform podcast and radio player",
    "homepage": "https://github.com/podradio/podradio",
    "license": "MIT",
    "supports": "(linux | osx | windows) & (x64 | arm64)",
    "dependencies": [
        "curl",
        "sqlite3",
        "libxml2",
        "fmt",
        "nlohmann-json",
        {
            "name": "ncurses",
            "platform": "!windows"
        },
        {
            "name": "pdcurses",
            "platform": "windows"
        }
    ]
}
